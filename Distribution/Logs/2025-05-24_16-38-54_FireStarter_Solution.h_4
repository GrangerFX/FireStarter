    n *= r2;
    n += 3.12569070f;
    r2 = n *= 0.60956484f;
    n *= r2;
    n *= r3;
    n *= r1;
    n *= r4;
    n += 0.84909135f;
    n *= -0.29522520f;
    n *= r0;
    return n;
} // Solution
