    n *= -4.39141989f;
    r3 = n *= 1.35125077f;
    r4 = n *= -0.53795934f;
    n *= -1.06284666f;
    n *= 1.03659177f;
    n = r4 += n;
    n += r1;
    r1 = n *= 0.58854896f;
    n *= -1.43817258f;
    n *= -10.62084007f;
    n += r3;
    r3 = n *= -5.61241150f;
