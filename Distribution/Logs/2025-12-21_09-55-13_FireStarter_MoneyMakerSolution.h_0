inline float MoneyMakerSolution(MoneyMakerStock& stock)
{
    float n = 0.0f;
    float r0 = 0.10877547f;
    float r1 = 2.27666640f;
    float r2 = 0.56961471f;
    float r3 = 0.76722795f;
    float r4 = -0.41673368f;
