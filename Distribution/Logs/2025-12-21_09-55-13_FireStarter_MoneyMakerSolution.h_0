    float r12 = -1.65099430f;
    float r13 = -0.66833156f;
    float r14 = 0.96508765f;

    for (unsigned int d = 0; d < stock.numDays; d++) {
        n = stock[d];
        r0 = n;
        n *= r1;
        n *= r2;
        r3 = n;
        r4 = n;
        n += r5;
        n += r6;
        n += r7;
        n *= r8;
        n *= r7;
        r3 = n;
        n *= r5;
        n *= r9;
        n *= r10;
