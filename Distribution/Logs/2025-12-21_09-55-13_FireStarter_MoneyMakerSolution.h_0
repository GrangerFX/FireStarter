        n += r13;
        n += r14;
        n += r0;
        n += r11;
        n += r11;
        n *= r4;
        n *= r2;
        n += r6;
        r8 = n;
        n *= r11;
        n *= r2;
    }
    return n;
} // MoneyMakerSolution
