#define SOLUTION_PI 3.14159265f
#define SOLUTION_MIN 0.0f
#define SOLUTION_MAX (2.0f * SOLUTION_PI)

inline float SolutionTarget(float n, unsigned int variation = 0)
{
    switch (variation & 3) {
        default:
        case 0:
            return sinf(n);
        case 1:
            return sinf((n + 0.4f) * 0.9f) - n * 0.2f + 0.5f;
        case 2:
            return sinf(n * 1.2f) + n * 0.2f;
        case 3:
            return fabsf(fmodf(fabsf(n - SOLUTION_PI * 0.5f), SOLUTION_PI * 2.0f) - SOLUTION_PI) - SOLUTION_PI * 0.5f;
    }
} // SolutionTarget

inline float Solution(float n)
{
    float r0, r1, r2, r3, r4;

    n += -3.14159274f;
    r0 = n *= -0.81909287f;
    r1 = n *= 0.00295884f;
    n *= r0;
    r0 = n *= 2.27626586f;
    r2 = n += -0.47743297f;
    r3 = n += -0.91182357f;
    n *= r2;
    n *= 7.91467762f;
    n += 0.11102393f;
    n *= r3;
    r3 = n += -1.63817954f;
    n += 7.79638815f;
    n *= r3;
    n += 2.01146412f;
    r3 = n *= -0.32723641f;
    r2 = n *= -2.50357389f;
    r4 = n += 5.77725649f;
    n += -3.86512876f;
    n *= -0.49077678f;
    n = r3 += n;
    n *= r3;
    n *= 0.30961490f;
    n += r2;
    n += -5.96220589f;
    n += -2.49780774f;
    n += 2.77753544f;
    n += r0;
    n += -1.86895669f;
    n *= 9.69676685f;
    n += r4;
    n *= r1;
    return n;
} // Solution
